# ── 서버 ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── 데이터베이스 (MongoDB Atlas 또는 로컬) ──────────────
# 예) mongodb+srv://user:pass@cluster0.xxxx.mongodb.net/incheon_funeral
MONGODB_URI=mongodb://127.0.0.1:27017/incheon_funeral

# ── 인증 ──────────────────────────────────────────────
# 세션(JWT) 서명 키 — 운영 환경에서는 반드시 긴 임의 문자열로 변경
JWT_SECRET=change-this-to-a-long-random-secret

# 초기 관리자 계정 (seed 스크립트 실행 시 생성)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234
ADMIN_NAME=시스템 관리자
